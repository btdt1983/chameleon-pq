# Rust build artifacts
/target/
/dist/
**/*.rs.bk

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# === SECURITY: never commit secrets ===
# Real configs with private keys/seeds (only the example may be tracked)
config.toml
config*.toml
# Catch any config with private keys regardless of prefix (e.g. client-config-pq.toml)
*config*.toml
!config.example.toml

# Sleutel-bestanden in elke vorm
*.key
*.pem
*.seed
*_secret*
*_private*

# Native libs kept locally for the Windows bundle (never commit/publish these).
# wintun.dll is redistributed via the GitHub release, not the crate.
*.dll

# Local environment overrides
.env
.env.local

# Ad-hoc screenshots dropped at the repo root during debugging (e.g. speed-test
# results shared in chat) — root-anchored so it does NOT affect the real,
# tracked images that belong in the repo (docs/screenshot.jpg,
# gui/assets/*.png/*.ico). Without this, cargo's default "everything not
# gitignored" packaging rule would sweep a stray screenshot into the
# published crate.
/*.jpg
/*.JPG
/*.jpeg
/*.JPEG
/*.png
/*.PNG
